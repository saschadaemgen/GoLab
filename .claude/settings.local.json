{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "MultiEdit",
      "Write",
      "Bash(*)",
      "WebSearch",
      "WebFetch(domain:pkg.go.dev)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:cdn.jsdelivr.net)",
      "WebFetch(domain:highlightjs.org)",
      "WebFetch(domain:quilljs.com)"
    ],
    "deny": [
      "Bash(*rm -rf*)",
      "Bash(*sudo*)",
      "Bash(*git push*)",
      "Bash(*git remote*)",
      "Bash(*go mod edit -go*)",
      "Bash(*DROP TABLE*)",
      "Bash(*DROP COLUMN*)",
      "Bash(*goose down*)",
      "Bash(*migrate-down*)"
    ]
  }
}
